## EKS Stack Configuration
## Copy this file to config.env and fill in your AWS-specific values
## Usage: cp config.env.example config.env

# AWS Region
export AWS_REGION=us-east-1

# EKS Cluster
export EKS_CLUSTER_NAME=conduktor-eks
export KUBE_CONTEXT="arn:aws:eks:${AWS_REGION}:ACCOUNT_ID:cluster/${EKS_CLUSTER_NAME}"

# Domain names for externally accessible services
# Use .conduktor.test with /etc/hosts for local testing (see PREREQUISITE.md Step 10)
# Replace with real domains if you have them
export CONSOLE_DOMAIN=console.conduktor.test
export GATEWAY_DOMAIN=gateway.conduktor.test
export OIDC_DOMAIN=oidc.conduktor.test

# ACM Certificate ARN for ALB HTTPS listeners
# For local .test domains, import a self-signed certificate into ACM (see PREREQUISITE.md Step 11)
export ACM_CERTIFICATE_ARN=arn:aws:acm:REGION:ACCOUNT:certificate/ID

# S3 bucket for Cortex monitoring storage (replaces MinIO)
export S3_BUCKET_NAME=conduktor-monitoring
export S3_REGION=${AWS_REGION}

# IRSA role ARN for Cortex S3 access
export CORTEX_IRSA_ROLE_ARN=arn:aws:iam::ACCOUNT:role/conduktor-cortex-s3

# VPC ID for AWS Load Balancer Controller
export VPC_ID=vpc-xxxxxxxxx

# IRSA role ARN for AWS Load Balancer Controller
export AWS_LB_CONTROLLER_IRSA_ROLE_ARN=arn:aws:iam::ACCOUNT:role/aws-load-balancer-controller
